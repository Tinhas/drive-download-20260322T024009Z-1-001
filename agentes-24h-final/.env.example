# =============================================================================
# agentes-24h-final — Variáveis de ambiente
# Copie para .env e preencha. NUNCA commite o .env real!
# =============================================================================

# ---------------------------------------------------------------------------
# Segurança interna (key-manager ↔ workers)
# Gere: python -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------------------
KM_AUTH_TOKEN=TROQUE_POR_TOKEN_ALEATORIO_SEGURO

# ---------------------------------------------------------------------------
# Flower — monitor Celery em http://localhost:5555
# ---------------------------------------------------------------------------
FLOWER_USER=admin
FLOWER_PASSWORD=TROQUE_POR_SENHA_FORTE

# ---------------------------------------------------------------------------
# Git — identidade nos commits automáticos
# ---------------------------------------------------------------------------
GIT_USER_EMAIL=agente@seudominio.com
GIT_USER_NAME=Agente Autonomo

# ---------------------------------------------------------------------------
# Ollama — modelo local (grátis, sem rate-limit)
# Opções leves: phi3:mini (~2GB), tinyllama (~1GB)
# Opções melhores: mistral:7b (~4GB), gemma:2b (~2GB)
# ---------------------------------------------------------------------------
OLLAMA_DEFAULT_MODEL=phi3:mini

# ---------------------------------------------------------------------------
# Provedores de IA — FREE TIERS
# Groq:       https://console.groq.com/keys
# OpenRouter: https://openrouter.ai/keys
# TogetherAI: https://api.together.ai/settings/api-keys
# FireworksAI:https://fireworks.ai/settings/api-keys
# Gemini:     https://aistudio.google.com/app/apikey
# ---------------------------------------------------------------------------
GROQ_API_KEY=
OPENROUTER_API_KEY=
TOGETHERAI_API_KEY=
FIREWORKSAI_API_KEY=
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Firecrawl — raspagem web (https://firecrawl.dev)
# ---------------------------------------------------------------------------
FIRECRAWL_API_KEY=

# ---------------------------------------------------------------------------
# GitHub — para push automático nas branches dos agentes
# ---------------------------------------------------------------------------
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# MCP Gateway HTTP (porta 8080 — acessível na rede local)
# ---------------------------------------------------------------------------
MCP_GATEWAY_PORT=8080
# Seu IP local para acessar pelo celular: ex: 192.168.1.100
HOST_IP=localhost

# ---------------------------------------------------------------------------
# Intervalos das tarefas (em segundos) — ajuste para não estourar free tier
# ---------------------------------------------------------------------------
TASK_FIX_BUGS_INTERVAL=3600        # 1h
TASK_ADD_FEATURE_INTERVAL=7200     # 2h
TASK_REFACTOR_INTERVAL=14400       # 4h
TASK_PEN_TEST_INTERVAL=86400       # 1x/dia
TASK_IMPROVE_SELF_INTERVAL=43200   # 2x/dia
TASK_HEALTH_CHECK_INTERVAL=300     # 5min

# ---------------------------------------------------------------------------
# Proteção de recursos — limites para não estourar RAM/CPU
# ---------------------------------------------------------------------------
CELERY_CONCURRENCY=2               # workers por container
OLLAMA_NUM_PARALLEL=1              # inferências paralelas no Ollama

# =============================================================================
# agentes-24h – Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores.
# O instalador faz isso automaticamente de forma interativa.
# NUNCA commite o .env real no Git!
# =============================================================================

# ---------------------------------------------------------------------------
# Segurança interna entre key-manager e workers
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------------------
KM_AUTH_TOKEN=TROQUE_POR_TOKEN_ALEATORIO_SEGURO

# ---------------------------------------------------------------------------
# Flower (monitoramento Celery) – acesso via http://localhost:5555
# ---------------------------------------------------------------------------
FLOWER_USER=admin
FLOWER_PASSWORD=TROQUE_POR_SENHA_FORTE

# ---------------------------------------------------------------------------
# Git – identidade usada nos commits automáticos
# ---------------------------------------------------------------------------
GIT_USER_EMAIL=agente@seudominio.com
GIT_USER_NAME=Agente Autonomo

# ---------------------------------------------------------------------------
# Ollama – modelo padrão para tarefas leves
# Opções: phi3:mini, tinyllama, gemma:2b, mistral:7b (mais pesado)
# ---------------------------------------------------------------------------
OLLAMA_DEFAULT_MODEL=phi3:mini

# ---------------------------------------------------------------------------
# OpenRouter (preenchido pelo instalador a partir de secrets/openrouter_key.txt)
# Deixe em branco aqui; o key-manager lê do arquivo de secret.
# ---------------------------------------------------------------------------
# OPENROUTER_API_KEY=

# ---------------------------------------------------------------------------
# Gemini CLI (configurado via 'gemini auth' no host, não via container)
# ---------------------------------------------------------------------------
# GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Intervalo das tarefas recorrentes (em segundos)
# ---------------------------------------------------------------------------
TASK_FIX_BUGS_INTERVAL=3600        # a cada 1 hora
TASK_ADD_FEATURE_INTERVAL=7200     # a cada 2 horas
TASK_REFACTOR_INTERVAL=14400       # a cada 4 horas
TASK_PEN_TEST_INTERVAL=86400       # 1x por dia
TASK_IMPROVE_SELF_INTERVAL=43200   # 2x por dia

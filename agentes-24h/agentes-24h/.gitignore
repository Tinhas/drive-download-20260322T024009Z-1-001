# =============================================================================
# .gitignore – agentes-24h
# =============================================================================

# Variáveis de ambiente reais
.env

# Secrets (chaves, tokens OAuth, etc.)
secrets/
!secrets/.gitkeep

# Dados gerados em runtime
data/
!data/.gitkeep

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/

# Logs
*.log
logs/

# Docker
*.tar

# OS
.DS_Store
Thumbs.db

п»ї# =============================================================================
# agentes-24h Гўв‚¬вЂњ VariГѓВЎveis de ambiente
# Copie este arquivo para .env e preencha os valores.
# O instalador faz isso automaticamente de forma interativa.
# NUNCA commite o .env real no Git!
# =============================================================================

# ---------------------------------------------------------------------------
# SeguranГѓВ§a interna entre key-manager e workers
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------------------
KM_AUTH_TOKEN=TROQUE_POR_TOKEN_ALEATORIO_SEGURO

# ---------------------------------------------------------------------------
# Flower (monitoramento Celery) Гўв‚¬вЂњ acesso via http://localhost:5555
# ---------------------------------------------------------------------------
FLOWER_USER=admin
FLOWER_PASSWORD=TROQUE_POR_SENHA_FORTE

# ---------------------------------------------------------------------------
# Git Гўв‚¬вЂњ identidade usada nos commits automГѓВЎticos
# ---------------------------------------------------------------------------
GIT_USER_EMAIL=agente@seudominio.com
GIT_USER_NAME=Agente Autonomo

# ---------------------------------------------------------------------------
# Ollama Гўв‚¬вЂњ modelo padrГѓВЈo para tarefas leves
# OpГѓВ§ГѓВµes: phi3:mini, tinyllama, gemma:2b, mistral:7b (mais pesado)
# ---------------------------------------------------------------------------
OLLAMA_DEFAULT_MODEL=phi3:mini

# ---------------------------------------------------------------------------
# Provedores de IA - FREE TIERS
# Obtenha suas chaves gratuitas em:
#   Groq: https://console.groq.com/keys
#   OpenRouter: https://openrouter.ai/keys
#   TogetherAI: https://api.together.ai/settings/api-keys
#   FireworksAI: https://fireworks.ai/settings/api-keys
#   Gemini: https://aistudio.google.com/app/apikey
# ---------------------------------------------------------------------------
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
# TOGETHERAI_API_KEY=
# FIREWORKSAI_API_KEY=
# GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Intervalo das tarefas recorrentes (em segundos)
# ---------------------------------------------------------------------------
TASK_FIX_BUGS_INTERVAL=3600        # a cada 1 hora
TASK_ADD_FEATURE_INTERVAL=7200     # a cada 2 horas
TASK_REFACTOR_INTERVAL=14400       # a cada 4 horas
TASK_PEN_TEST_INTERVAL=86400       # 1x por dia
TASK_IMPROVE_SELF_INTERVAL=43200   # 2x por dia
